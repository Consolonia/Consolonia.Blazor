<local:App xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:console="https://github.com/consolonia"
           xmlns:themes="using:Consolonia.ManagedWindows"
           xmlns:local="using:Example.Blazor"
           x:Class="Example.Blazor.App">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <console:ModernTheme />
        <themes:AutoManagedWindowStyles />
    </Application.Styles>
</local:App>